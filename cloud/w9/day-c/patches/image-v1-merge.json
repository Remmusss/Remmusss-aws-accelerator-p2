{
  "spec": {
    "template": {
      "spec": {
        "containers": [
          {
            "name": "demo-web",
            "image": "demo-web-metrics:v1",
            "imagePullPolicy": "IfNotPresent",
            "env": [
              {
                "name": "APP_NAME",
                "value": "demo-web-rollout"
              },
              {
                "name": "APP_VERSION",
                "value": "v1"
              }
            ],
            "ports": [
              {
                "containerPort": 8000,
                "name": "http"
              }
            ],
            "readinessProbe": {
              "httpGet": {
                "path": "/healthz",
                "port": "http"
              },
              "initialDelaySeconds": 5,
              "periodSeconds": 5
            },
            "livenessProbe": {
              "httpGet": {
                "path": "/healthz",
                "port": "http"
              },
              "initialDelaySeconds": 15,
              "periodSeconds": 10
            }
          }
        ]
      }
    }
  }
}
